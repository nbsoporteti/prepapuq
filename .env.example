# =====================================================================
# PrePa — environment variables
# Copy this file to .env (root) and fill in the values for your deploy.
# =====================================================================

# --- Frontend (apps/web) ---------------------------------------------
# Public URL of the PocketBase API. Baked into the bundle at build time.
# Local dev (via docker-compose):   http://localhost:8090
# Local dev (no docker, npm run dev): /hcgi/platform  (proxied by Vite)
# Coolify / VPS:                    https://api.prepapuq.cl
VITE_POCKETBASE_URL=http://localhost:8090

# --- Backend (apps/pocketbase) ---------------------------------------
# Optional. If set, PocketBase encrypts its settings at rest with this key.
# Use a 32-character random string. To generate one:
#   openssl rand -hex 16
# Leaving it empty is fine for first boot; rotate later by recreating the
# container with a new value AFTER backing up pb_data.
PB_ENCRYPTION_KEY=

# --- Asistente de IA (apps/pocketbase, opcional) ---------------------
# Habilita el chat de ayuda técnica con Claude. La clave vive SOLO en el
# backend (este contenedor), NUNCA en el frontend ni en el bundle. Si no la
# seteás, el asistente queda deshabilitado (responde "no configurado").
# Conseguí una clave en https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=
# Modelo a usar. Default: claude-opus-4-8 (el más capaz). Para bajar mucho el
# costo, poné claude-haiku-4-5 (rápido y barato, suficiente para ayuda de uso).
ANTHROPIC_MODEL=claude-opus-4-8
