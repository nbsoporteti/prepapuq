# =====================================================================
# PrePa — environment variables
# Copy this file to .env (root) and fill in the values for your deploy.
# =====================================================================

# --- Frontend (apps/web) ---------------------------------------------
# Public URL of the PocketBase API. Baked into the bundle at build time.
# Local dev (via docker-compose):   http://localhost:8090
# Local dev (no docker, npm run dev): /hcgi/platform  (proxied by Vite)
# Coolify / VPS:                    https://api.tudominio.cl
VITE_POCKETBASE_URL=http://localhost:8090

# --- Backend (apps/pocketbase) ---------------------------------------
# Optional. If set, PocketBase encrypts its settings at rest with this key.
# Use a 32-character random string. To generate one:
#   openssl rand -hex 16
# Leaving it empty is fine for first boot; rotate later by recreating the
# container with a new value AFTER backing up pb_data.
PB_ENCRYPTION_KEY=
